# ── Groq (free cloud LLM) ────────────────────────────────────────────
# Get free key: https://console.groq.com  →  API Keys  →  Create key
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# Other good Groq models: mixtral-8x7b-32768  llama3-8b-8192  gemma2-9b-it

# ── Ollama (local LLM, 100% free) ────────────────────────────────────
# Install: https://ollama.com/download  then:  ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── LLM strategy ─────────────────────────────────────────────────────
# groq   → always use Groq
# ollama → always use Ollama
# auto   → Groq first, fall back to Ollama if unavailable
LLM_PROVIDER=auto

# ── Embeddings (runs locally, no API key needed) ─────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Vector store ─────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=data/embeddings/chroma

# ── API ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

